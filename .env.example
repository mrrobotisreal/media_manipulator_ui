# Copy to .env.local and fill in. NEXT_PUBLIC_* vars are exposed to the browser.

# --- AdSense / ads ---
# AdSense is OFF unless this is 'true' AND NODE_ENV=production AND the
# page/placement/slot pass the guards in lib/adsenseConfig.ts.
NEXT_PUBLIC_ADSENSE_ENABLED=false
# First-party mock ad previews (non-production only). Never loads Google.
NEXT_PUBLIC_MOCK_ADS_ENABLED=true
# Recommended for the AdSense review deployment:
#   NEXT_PUBLIC_ADSENSE_ENABLED=false
#   NEXT_PUBLIC_MOCK_ADS_ENABLED=false

# --- API / analytics ---
NEXT_PUBLIC_API_BASE_URL="https://api.media-manipulator.com/api"
NEXT_PUBLIC_ANALYTICS_BASE_URL="https://analytics.media-manipulator.com"
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-6J910CMHRY"
NEXT_PUBLIC_MP_TOKEN=""

# --- Firebase (web; public by design) ---
NEXT_PUBLIC_FB_API_KEY=""
NEXT_PUBLIC_FB_AUTH_DOMAIN=""
NEXT_PUBLIC_FB_PROJECT_ID=""
NEXT_PUBLIC_FB_STORAGE_BUCKET=""
NEXT_PUBLIC_FB_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FB_APP_ID=""
NEXT_PUBLIC_FB_MEASUREMENT_ID=""
